meta {
  name: Create Product
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/products
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "name": "Wireless Mouse",
    "description": "Ergonomic wireless mouse",
    "price": 29.99,
    "quantity": 100,
    "category": "Accessories"
  }
}

script:post-response {
  if (res.body && res.body.id) {
    bru.setVar("productId", res.body.id);
  }
}

assert {
  res.status: eq 201
}
