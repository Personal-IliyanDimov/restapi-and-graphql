meta {
  name: Delete Product
  type: graphql
  seq: 6
}

post {
  url: {{baseUrl}}/graphql
  body: graphql
  auth: none
}

headers {
  Content-Type: application/json
}

body:graphql {
  mutation DeleteProduct($id: ID!) {
    deleteProduct(id: $id)
  }
}

body:graphql:vars {
  {
    "id": "{{productId}}"
  }
}

assert {
  res.status: eq 200
}
